---
// Projektseite "Ωracles 'Melt Tonight'" — Struktur 2026 überarbeitet:
// Loops → einzeilige Notiz → Presse-Logos → Player → Credits (Filmplakat-Stil).
import Img from '../Img.astro';
import BgVideo from '../BgVideo.astro';
import PosterCredits from '../PosterCredits.astro';
import { inline } from '../../lib/text';

const { data } = Astro.props;
const { singleLoop, loopGrid, pressLogos, player, credits, outro } = data;

const loopIds = [
  { wrapperId: 'w-node-_1af0dc54-d5f8-f6a6-322a-1aaf1b431d70-7dc3692c', videoId: '1af0dc54-d5f8-f6a6-322a-1aaf1b431d70-video' },
  { wrapperId: 'w-node-b921e0fe-b6a6-86b2-0c6e-9f7dc5a72e97-7dc3692c', videoId: 'b921e0fe-b6a6-86b2-0c6e-9f7dc5a72e97-video' },
  { wrapperId: 'w-node-a52f304e-3a92-4b45-d971-cc0ba56e8fe6-7dc3692c', videoId: 'a52f304e-3a92-4b45-d971-cc0ba56e8fe6-video' },
  { wrapperId: 'w-node-dcfa8e54-0da8-0f20-1508-a24ef5600a37-7dc3692c', videoId: 'dcfa8e54-0da8-0f20-1508-a24ef5600a37-video' },
];

const playerSrc = `https://player.vimeo.com/video/${player.vimeoId}?autoplay=0&loop=0&autopause=1&muted=0&portrait=0&byline=0&title=0&dnt=1`;
---
<div class="fp-press">
  {pressLogos.map((img: any) => (
    <Img src={img.src} alt={img.alt} />
  ))}
</div>
<div class="div-block-62-copy">
  <div class="fp-play-main">
    <BgVideo base={singleLoop} videoId="718e24c9-7e9f-f397-1b4e-9f79eb09dad4-video" wrapperClass="background-video-4" />
  </div>
</div>
<div class="div-block-61-copy">
  <div class="w-layout-grid grid-8">
    {loopGrid.map((base: string, i: number) => (
      <BgVideo base={base} wrapperId={loopIds[i]?.wrapperId} videoId={loopIds[i]?.videoId ?? `oracles-loop-${i}-video`} wrapperClass="background-video-3" />
    ))}
  </div>
</div>
<div class="capital text-size centered fp-oracles-note" set:html={inline(outro)}></div>
<div class="video-div luz">
  <div id="placeholder_oracles" class="placeholder vimeo-video">
    <div class="capital video-error-message">To view this video please accept cookies. </div>
    <a fs-cc="open-preferences" href="#" class="open-cookies-button capital w-button">Manage cookies</a>
  </div>
  <div style="display:none;padding-top:56.25%" class="vimeo-video w-video w-embed"><iframe fs-cc-src={playerSrc} fs-cc-placeholder="#placeholder_oracles" fs-cc-category="analytics" frameborder="0" allow="autoplay; fullscreen" allowfullscreen title={player.title}></iframe></div>
  <div data-w-id="763717ab-5934-04cc-a543-ee8dd4ea9794" class="video-thumbnail oracles"></div><img src="/images/Click-to-Watch-mit-Pfeil-small.png" loading="lazy" alt="" class="cta-img">
</div>
<PosterCredits entries={credits} />
