---
// Selbstgehostetes MP4-Video (Custom Code-Embed) mit Mute-Button,
// wie auf der Startseite (Showreel + Trailer-Teaser).
interface Props {
  src: string;
  /** 'hero' = Startseiten-Showreel (versteckt, contain), 'teaser' = Trailer-Block */
  variant?: 'hero' | 'teaser';
}
const { src, variant = 'teaser' } = Astro.props;
const isHero = variant === 'hero';
---
<div style={isHero ? 'display:none' : undefined} class={isHero ? 'code-embed show-reel w-embed' : 'code-embed w-embed'}>
  <div class="video-wrapper" style="position: relative;">
    <video class="bg-video" autoplay muted playsinline disablepictureinpicture disableremoteplayback controlslist="nodownload noremoteplayback noplaybackrate" style={isHero ? 'width: 100%; height: 100%; object-fit: contain;' : 'width: 100%; height: auto; object-fit: cover;'}>
      <source src={src} type="video/mp4">
      Your browser does not support the video tag.
    </video>
    <div class="fp-sound-badge" aria-hidden="true">
      <svg class="fp-snd-waves" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round">
        <path d="M5 12 h5 l7 -6 v20 l-7 -6 h-5 z"></path>
        <path d="M21 12 a6 6 0 0 1 0 8"></path>
        <path d="M24.5 8.5 a11 11 0 0 1 0 15"></path>
      </svg>
      <svg class="fp-snd-x" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round">
        <path d="M5 12 h5 l7 -6 v20 l-7 -6 h-5 z"></path>
        <path d="M21.5 12.5 L28.5 19.5"></path>
        <path d="M28.5 12.5 L21.5 19.5"></path>
      </svg>
    </div>
  </div>
</div>
