---
// Basis-Layout: repliziert den <head> und die Script-Einbindung des
// Webflow-Exports exakt (Typekit, Cookie-Consent, jQuery, webflow.js).
interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  /** Volle OG/Twitter-Metas (og:description, og:type, twitter:card) wie auf say-wuff */
  fullOg?: boolean;
  /** Webflow-Page-ID für data-wf-page (steuert seitenspezifische Interaktionen) */
  wfPageId: string;
  bodyClass: string;
  /** Scrollbar-verstecken-Styleblock am Seitenende (Original: überall außer legal) */
  scrollbarStyle?: boolean;
}
const {
  title,
  description,
  ogTitle,
  fullOg = false,
  wfPageId,
  bodyClass,
  scrollbarStyle = true,
} = Astro.props;

// Cache-Buster: ändert sich bei jedem Build, damit Browser (v. a. Safari)
// nach einem Deploy nie mit veraltetem CSS/JS rendern.
const v = Date.now().toString(36);
---

<!DOCTYPE html>
<html data-wf-page={wfPageId} data-wf-site="6a4619bec66319687dc36933">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  {description && <meta content={description} name="description">}
  {ogTitle && <meta content={ogTitle} property="og:title">}
  {fullOg && description && <meta content={description} property="og:description">}
  {ogTitle && <meta content={ogTitle} name="twitter:title">}
  {fullOg && description && <meta content={description} name="twitter:description">}
  {fullOg && <meta property="og:type" content="website">}
  {fullOg && <meta content="summary_large_image" name="twitter:card">}
  <meta content="width=device-width, initial-scale=1" name="viewport">
  <link href={`/css/normalize.css?v=${v}`} rel="stylesheet" type="text/css">
  <link href={`/css/webflow.css?v=${v}`} rel="stylesheet" type="text/css">
  <link href={`/css/fabi-com-e36e8420f13770a83897a3b1c047db.webflow.css?v=${v}`} rel="stylesheet" type="text/css">
  <link href={`/css/fonts.css?v=${v}`} rel="stylesheet" type="text/css">
  <link href={`/css/site.css?v=${v}`} rel="stylesheet" type="text/css">
  <script is:inline src="https://use.typekit.net/ntq5han.js" type="text/javascript"></script>
  <script is:inline type="text/javascript">try{Typekit.load();}catch(e){}</script>
  <script is:inline type="text/javascript">!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>
  <link href="/images/favicon.png" rel="shortcut icon" type="image/x-icon">
  <link href="/images/webclip.png" rel="apple-touch-icon">
  <!--  Finsweet Cookie Consent  -->
  <script is:inline async src="/js/fs-cc.js" fs-cc-mode="opt-in"></script>
</head>
<body class={bodyClass}>
  <slot />
  <script is:inline src="/js/jquery-3.5.1.min.js" type="text/javascript"></script>
  <script is:inline src={`/js/webflow.js?v=${v}`} type="text/javascript"></script>
  <script is:inline src={`/js/site.js?v=${v}`} type="text/javascript"></script>
  {scrollbarStyle && <style is:inline>
/* width */
::-webkit-scrollbar {
  width: 0px;
}
/* Track */
::-webkit-scrollbar-track {
  background: transparent;
}
/* Handle */
::-webkit-scrollbar-thumb {
  background: transparent;
}
/* Handle on hover */
::-webkit-scrollbar-thumb:hover {
  background: transparent;
}
body { -webkit-font-smoothing: antialiased; }
body { overflow: -moz-scrollbars-none; -ms-overflow-style: none;  }
:root{
  scrollbar-width: none !important;
}
body{
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
</style>}
  <slot name="tail" />
</body>
</html>
