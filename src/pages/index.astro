---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import MobileMenu from '../components/MobileMenu.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Img from '../components/Img.astro';
import BgVideo from '../components/BgVideo.astro';
import CodeEmbedVideo from '../components/CodeEmbedVideo.astro';
import { getNav } from '../lib/nav';
import { inline } from '../lib/text';

const home = (await getEntry('globals', 'home'))!.data as any;
const nav = await getNav('home');
const wfPageId = '6a4619bec66319687dc36922';

// Feste IX2-IDs der Startseiten-Video-Loops (aus dem Original übernommen)
const milkyVideoIds = [
  '3c797a5b-92f3-ea2f-3cca-e8c419b1c9a7-video',
  '3c797a5b-92f3-ea2f-3cca-e8c419b1c9a8-video',
  '3c797a5b-92f3-ea2f-3cca-e8c419b1c9a9-video',
];
const oraclesVideos = [
  { wrapperId: undefined, videoId: '60cb6a01-5c61-8492-9792-d82f7607be85-video', class: 'background-video-8' },
  { wrapperId: 'w-node-e3df307f-d07a-1f36-53fb-d4878e667b4f-7dc36922', videoId: 'e3df307f-d07a-1f36-53fb-d4878e667b4f-video', class: 'background-video-10' },
  { wrapperId: undefined, videoId: 'ae8d3eb1-c37d-f7e9-587b-78be00c0d1a9-video', class: 'background-video-10' },
];
---

<Base title={home.title} wfPageId={wfPageId} bodyClass="body">
  <MobileMenu nav={nav} current="home" />
  <Sidebar nav={nav} current="home" worksClicked={true} />
  <div class="main-body">
    <div class="hero-landing">
      <div class="hello-div"><img src="/images/Sticker-Fabi-Neu.png" loading="lazy" alt="" class="fabi-sticker hide-mobil"><Img src={home.hero.welcomeImage} class="image-25" /><Img src={home.hero.welcomeText} class="image-36" /></div>
      <div id="showreel" class="video-div showreel">
        <div id="placeholder_showreel" class="placeholder vimeo-video">
          <div class="capital video-error-message">To view this video please accept cookies. </div>
          <a fs-cc="open-preferences" href="#" class="open-cookies-button capital w-button">Manage cookies</a>
        </div>
        <CodeEmbedVideo src={home.hero.showreelMp4} variant="hero" />
        <BgVideo base={home.hero.thumbnailVideo} dataWId="3c865caf-5d46-6362-b319-60fe1f58e2f4" videoId="3c865caf-5d46-6362-b319-60fe1f58e2f4-video" wrapperClass="video-thumbnail showreel" /><Img src="/images/Click-to-Watch-mit-Pfeil-small.png" class="cta-img" />
      </div>
    </div>
    {home.sections.map((s: any) => {
      const wrapperClass = s.layout === 'junk-landing' ? 'junk-jornal-div' : 'main-film-layout';
      return (
        <div class={wrapperClass}>
          <div class="heading-div">
            <a href={s.link} class="fp-heading-link"><h1 class="h1 text-size" set:html={inline(s.heading)}></h1><img src="/images/Line.png" loading="lazy" alt="" class={s.lineMobil ? 'line mobil' : 'line'} /></a>
            <div class="capital text-size centered" set:html={inline(s.meta)}></div>
          </div>

          {s.layout === 'say-wuff-landing' && (
            <div class="w-layout-grid grid say-wuff landing">
              <a href={s.link} class="w-inline-block"><Img src={s.poster} class="img-in-grid" /></a>
              <a href={s.link} class="grid-inner-div index say-wuff w-inline-block">
                {s.images.map((img: any) => (
                  <Img src={img.src} id={img.id} class="img-in-grid cut" alt={img.alt} />
                ))}
              </a>
            </div>
          )}

          {s.layout === 'milky-landing' && (
            <a href={s.link} class="w-inline-block">
              <div class="w-layout-grid grid-7"><Img src={s.poster} class="image-35" />
                <div id="w-node-_3c797a5b-92f3-ea2f-3cca-e8c419b1c9a6-7dc36922" class="div-block-66">
                  {s.videos.map((base: string, i: number) => (
                    <BgVideo base={base} videoId={milkyVideoIds[i] ?? `home-milky-${i}-video`} wrapperClass="milky-backround-video" />
                  ))}
                </div>
              </div>
            </a>
          )}

          {s.layout === 'oracles-landing' && (
            <div class="w-layout-grid grid-9">
              <div id="w-node-_673b79ac-6560-3bc8-b097-9782c434ed26-7dc36922" class="fp-play-main w-inline-block" data-vimeo-id={s.vimeoId}>
                <BgVideo base={s.videos[0]} videoId={oraclesVideos[0].videoId} wrapperClass={oraclesVideos[0].class} />
              </div>
              {s.videos.slice(1).map((base: string, i: number) => (
                <a id={oraclesVideos[i + 1]?.wrapperId} href={s.link} class="fp-loop-link w-inline-block">
                  <BgVideo base={base} videoId={oraclesVideos[i + 1]?.videoId ?? `home-oracles-${i}-video`} wrapperClass={oraclesVideos[i + 1]?.class ?? 'background-video-10'} />
                </a>
              ))}
            </div>
          )}

          {s.layout === 'junk-landing' && (
            <a href={s.link} class="junk-div w-inline-block">
              {s.images.map((img: any) => (
                <Img src={img.src} sizes={img.sizes} class="junk-img" alt={img.alt} />
              ))}
            </a>
          )}

          {s.layout === 'luz-landing' && (
            <div class="w-layout-grid grid luz landing">
              <a href={s.link} class="w-inline-block"><Img src={s.poster} class="image-in-grid" /></a>
              <a href={s.link} class="grid-inner-div w-inline-block">
                {s.images.map((img: any) => (
                  <Img src={img.src} id={img.id} class="image-in-grid" alt={img.alt} />
                ))}
              </a>
            </div>
          )}

          {s.teaserMp4 && <CodeEmbedVideo src={s.teaserMp4} variant="teaser" playOverlay={true} />}

          {s.textLeft && (
            <div class="film-text landing">
              <div class="capital text-size fp-film-note" set:html={inline(s.textLeft)}></div>
            </div>
          )}

          <a href={s.link} class="div-block-65 w-inline-block"><img src="/images/More-Here-klein.png" loading="lazy" alt="" class="image-34 gelb"><img src="/images/More-Here-klein-hover.png" loading="lazy" data-w-id="8fa63e34-41d9-fd0b-4fcc-428bb874a7a0" alt="" class="image-33"></a>
        </div>
      );
    })}
  </div>
  <CookieConsent wfPageId={wfPageId} />
</Base>
